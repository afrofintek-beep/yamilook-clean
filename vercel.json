{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/store/",
      "destination": "/store/index.html"
    },
    {
      "source": "/store",
      "destination": "/store/index.html"
    },
    {
      "source": "/app",
      "destination": "/app/index.html"
    },
    {
      "source": "/app/",
      "destination": "/app/index.html"
    },
    {
      "source": "/guia",
      "destination": "/guia/index.html"
    },
    {
      "source": "/guia/",
      "destination": "/guia/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}